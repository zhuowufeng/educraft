{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/courseware/(.*)", "dest": "/courseware/$1" },
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
